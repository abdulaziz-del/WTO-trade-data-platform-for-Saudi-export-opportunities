# ============================================================
# WTO Trade Intelligence Platform — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Application ---
DEBUG=false
SECRET_KEY=replace-with-strong-random-string-min-32-chars

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/wto_platform

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Elasticsearch ---
ELASTICSEARCH_URL=http://localhost:9200

# --- AI (Anthropic Claude) ---
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ============================================================
# WTO API KEY
# 1. Go to https://apiportal.wto.org
# 2. Click "Sign Up" (free registration)
# 3. Subscribe to: "ePing", "Quantitative Restrictions",
#    "Time Series", "TFAD" products
# 4. Copy your key from Profile > Subscriptions
# ============================================================
WTO_API_KEY=your-wto-api-key-here

# --- JWT ---
JWT_SECRET_KEY=replace-with-another-strong-random-string

# --- AWS S3 (for report storage) ---
AWS_REGION=me-south-1
AWS_S3_BUCKET=wto-platform-files
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- CORS ---
# Comma-separated list
ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com
